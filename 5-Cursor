mysql> CREATE PROCEDURE Appraisal_With_Exception()
    -> BEGIN
    ->     DECLARE done INT DEFAULT 0;
    ->     DECLARE v_id INT;
    ->     DECLARE v_salary INT;
    ->     DECLARE v_rating INT;
    ->     DECLARE v_bonus VARCHAR(30);
    ->
    ->     -- Cursor
    ->     DECLARE emp_cursor CURSOR FOR
    ->         SELECT Id, Salary, Rating FROM Employee;
    ->
    ->     -- Handlers
    ->     DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;
    ->
    ->     DECLARE EXIT HANDLER FOR SQLEXCEPTION
    ->     BEGIN
    ->         SELECT 'Error occurred during appraisal process' AS Message;
    ->     END;
    ->
    ->     OPEN emp_cursor;
    ->
    ->     read_loop: LOOP
    ->         FETCH emp_cursor INTO v_id, v_salary, v_rating;
    ->
    ->         IF done = 1 THEN
    ->             LEAVE read_loop;
    ->         END IF;
    ->
    ->         -- Control Structure
    ->         IF v_rating = 5 THEN
    ->             SET v_salary = v_salary + 10000;
    ->             SET v_bonus = 'Excellent';
    ->
    ->         ELSEIF v_rating = 4 THEN
    ->             SET v_salary = v_salary + 5000;
    ->             SET v_bonus = 'Good';
    ->
    ->         ELSEIF v_rating = 3 THEN
    ->             SET v_salary = v_salary + 2000;
    ->             SET v_bonus = 'Average';
    ->
    ->         ELSE
    ->             SET v_bonus = 'Needs Improvement';
    ->         END IF;
    ->
    ->         -- Update Employee
    ->         UPDATE Employee
    ->         SET Salary = v_salary
    ->         WHERE Id = v_id;
    ->
    ->         -- Insert into log table
    ->         INSERT INTO appraisal_log(Id, Action, old_salary, new_salary)
    ->         VALUES (v_id, v_bonus, v_salary - 0, v_salary);
    ->
    ->     END LOOP;
    ->
    ->     CLOSE emp_cursor;
    -> END$$
